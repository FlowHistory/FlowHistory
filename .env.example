# Django
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.76

# Timezone
TIME_ZONE=America/New_York

# Authentication (optional)
REQUIRE_AUTH=false
APP_PASSWORD=

# --- Instance Configuration ---
# Instances are auto-discovered from FLOWHISTORY_* env vars on startup.
# Credentials (_USER, _PASS) are always read from env at runtime, never stored in DB.

# Local instance (auto-discovered via _FLOWS_PATH)
FLOWHISTORY_LOCAL_FLOWS_PATH=/nodered-data/flows.json
# FLOWHISTORY_LOCAL_NAME=Docker Host

# Remote instance example (auto-discovered via _URL)
# FLOWHISTORY_PROD_URL=http://192.168.1.50:1880
# FLOWHISTORY_PROD_USER=admin
# FLOWHISTORY_PROD_PASS=secretpass
# FLOWHISTORY_PROD_NAME=Production
# FLOWHISTORY_PROD_SCHEDULE=daily
# FLOWHISTORY_PROD_TIME=03:00
# FLOWHISTORY_PROD_MAX_BACKUPS=30

# --- Notifications ---
# Per-instance notification control (optional)
# FLOWHISTORY_LOCAL_NOTIFY=true
# FLOWHISTORY_LOCAL_NOTIFY_EVENTS=backup_failed,restore_success,restore_failed

# Discord — global webhook (applies to all instances without their own)
# FLOWHISTORY_NOTIFY_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook
# Per-instance override:
# FLOWHISTORY_LOCAL_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/other/webhook

# Slack — global webhook
# FLOWHISTORY_NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# Per-instance override:
# FLOWHISTORY_LOCAL_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Telegram — global bot token and chat ID (both required)
# FLOWHISTORY_NOTIFY_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# FLOWHISTORY_NOTIFY_TELEGRAM_CHAT_ID=123456789
# Per-instance override:
# FLOWHISTORY_LOCAL_TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# FLOWHISTORY_LOCAL_TELEGRAM_CHAT_ID=123456789

# Pushbullet — global API key
# FLOWHISTORY_NOTIFY_PUSHBULLET_API_KEY=o.abc123...
# Per-instance override:
# FLOWHISTORY_LOCAL_PUSHBULLET_API_KEY=o.abc123...

# Home Assistant — global URL and long-lived access token (both required)
# FLOWHISTORY_NOTIFY_HOMEASSISTANT_URL=http://homeassistant.local:8123
# FLOWHISTORY_NOTIFY_HOMEASSISTANT_TOKEN=eyJ...
# Per-instance override:
# FLOWHISTORY_LOCAL_HOMEASSISTANT_URL=http://homeassistant.local:8123
# FLOWHISTORY_LOCAL_HOMEASSISTANT_TOKEN=eyJ...
